---
export interface Props {
  contactTitle: string;
  contactSubtitle: string;
  phone: string;
  email: string;
  address: string;
  capacity: string;
  instagram: string;
  instagramUrl: string;
}
const { contactTitle, contactSubtitle, phone, email, address, capacity, instagram, instagramUrl } = Astro.props;
---

<section
  id="contact"
  class="py-20 relative"
  style="background: linear-gradient(135deg, #f5f5dc 0%, #e8dcc4 100%)"
>
  <div
    class="absolute inset-0 pointer-events-none"
    style="background-image: radial-gradient(circle at 20% 50%, rgba(218,165,32,0.05) 0%, transparent 50%), radial-gradient(circle at 80% 80%, rgba(139,0,0,0.05) 0%, transparent 50%);"
  ></div>
  <div class="max-w-7xl mx-auto px-5 relative">
    <h2
      class="scroll-animate text-5xl text-center mb-12 text-primary"
      data-i18n="contactTitle"
    >
      {contactTitle}
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-5xl mx-auto">

      <!-- Contact Info -->
      <div class="scroll-slide-left bg-white p-10 rounded-3xl shadow-xl transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl">
        <h3
          data-i18n="contactSubtitle"
          class="text-3xl mb-8 text-primary text-center pb-4 border-b-4 border-secondary"
        >
          {contactSubtitle}
        </h3>

        {[
          { icon: "📞", labelI18n: "contactPhone", label: "Phone:", value: phone },
          { icon: "✉️", labelI18n: "contactEmail", label: "Email:", value: email },
          { icon: "📍", labelI18n: "contactAddress", label: "Address:", value: address },
          { icon: "👥", labelI18n: "contactCapacity", label: "Capacity:", value: capacity },
        ].map(({ icon, labelI18n, label, value }) => (
          <div
            class="flex items-center gap-5 p-5 mb-4 rounded-xl transition-all duration-300 border-2 border-secondary/20 shadow-sm hover:border-secondary hover:translate-x-2 hover:shadow-md"
            style="background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);"
          >
            <span
              class="text-4xl min-w-[50px] h-[50px] flex items-center justify-center rounded-full flex-shrink-0"
              style="background: linear-gradient(135deg, rgba(218,165,32,0.15), rgba(139,0,0,0.1));"
            >{icon}</span>
            <div class="flex-1">
              <strong
                data-i18n={labelI18n}
                class="text-primary text-sm font-bold tracking-wider uppercase"
              >{label}</strong>
              <p class="m-0 text-dark text-lg leading-relaxed font-medium">{value}</p>
            </div>
          </div>
        ))}

        <!-- Instagram -->
        <div
          class="flex items-center gap-5 p-5 mb-4 rounded-xl transition-all duration-300 border-2 border-secondary/20 shadow-sm hover:border-secondary hover:translate-x-2 hover:shadow-md"
          style="background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);"
        >
          <span
            class="text-4xl min-w-[50px] h-[50px] flex items-center justify-center rounded-full flex-shrink-0"
            style="background: linear-gradient(135deg, rgba(218,165,32,0.15), rgba(139,0,0,0.1));"
          >📷</span>
          <div class="flex-1">
            <strong
              data-i18n="contactInstagram"
              class="text-primary text-sm font-bold tracking-wider uppercase"
            >Instagram:</strong>
            <p class="m-0 text-dark text-lg leading-relaxed font-medium">
              <a
                href={instagramUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-secondary no-underline transition-all duration-300 font-semibold hover:text-primary hover:underline"
              >{instagram}</a>
            </p>
          </div>
        </div>
      </div>

      <!-- Booking Form -->
      <div class="scroll-slide-right bg-white p-10 rounded-3xl shadow-xl transition-all duration-300 hover:shadow-2xl">
        <form class="flex flex-col gap-4">
          <input
            type="text"
            placeholder="Your Name"
            data-i18n-placeholder="formName"
            required
            class="p-4 text-base border-2 border-gray-300 rounded-xl font-serif transition-all duration-300 bg-gray-50 hover:bg-white hover:border-secondary focus:outline-none focus:border-primary focus:bg-white focus:shadow-lg focus:ring-4 focus:ring-primary/10"
          />
          <input
            type="email"
            placeholder="Your Email"
            data-i18n-placeholder="formEmail"
            required
            class="p-4 text-base border-2 border-gray-300 rounded-xl font-serif transition-all duration-300 bg-gray-50 hover:bg-white hover:border-secondary focus:outline-none focus:border-primary focus:bg-white focus:shadow-lg focus:ring-4 focus:ring-primary/10"
          />
          <input
            type="tel"
            placeholder="Phone Number"
            data-i18n-placeholder="formPhone"
            required
            class="p-4 text-base border-2 border-gray-300 rounded-xl font-serif transition-all duration-300 bg-gray-50 hover:bg-white hover:border-secondary focus:outline-none focus:border-primary focus:bg-white focus:shadow-lg focus:ring-4 focus:ring-primary/10"
          />
          <select
            required
            class="p-4 text-base border-2 border-gray-300 rounded-xl font-serif transition-all duration-300 bg-gray-50 hover:bg-white hover:border-secondary focus:outline-none focus:border-primary focus:bg-white focus:shadow-lg focus:ring-4 focus:ring-primary/10"
          >
            <option value="" data-i18n="formEventType">Event Type</option>
            <option value="wedding" data-i18n="formEventWedding">Wedding</option>
            <option value="birthday" data-i18n="formEventBirthday">Birthday</option>
            <option value="corporate" data-i18n="formEventCorporate">Corporate Event</option>
            <option value="anniversary" data-i18n="formEventAnniversary">Anniversary</option>
            <option value="other" data-i18n="formEventOther">Other</option>
          </select>
          <input
            type="number"
            placeholder="Number of Guests"
            data-i18n-placeholder="formGuests"
            min="20"
            required
            class="p-4 text-base border-2 border-gray-300 rounded-xl font-serif transition-all duration-300 bg-gray-50 hover:bg-white hover:border-secondary focus:outline-none focus:border-primary focus:bg-white focus:shadow-lg focus:ring-4 focus:ring-primary/10"
          />
          <textarea
            placeholder="Tell us about your event..."
            data-i18n-placeholder="formMessage"
            rows="4"
            required
            class="p-4 text-base border-2 border-gray-300 rounded-xl font-serif transition-all duration-300 bg-gray-50 resize-none hover:bg-white hover:border-secondary focus:outline-none focus:border-primary focus:bg-white focus:shadow-lg focus:ring-4 focus:ring-primary/10"
          ></textarea>
          <button
            type="submit"
            data-i18n="formButton"
            class="inline-block bg-primary text-white px-10 py-4 text-xl no-underline rounded border-2 border-primary cursor-pointer font-bold transition-all duration-300 mt-2 hover:bg-transparent hover:border-secondary hover:text-secondary hover:-translate-y-1 shadow-xl hover:shadow-2xl"
          >
            Send Request
          </button>
        </form>
      </div>

    </div>
  </div>
</section>

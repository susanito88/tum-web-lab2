---
export interface Props {
  restaurantName: string;
  footerText: string;
}
const { restaurantName, footerText } = Astro.props;
---

<footer class="bg-dark text-white text-center py-8">
  <div class="max-w-7xl mx-auto px-5">
    <p class="text-base">
      &copy; 2026 {restaurantName} Restaurant.
      <span data-i18n="footerText">{footerText}</span>
    </p>
    <p class="mt-2 text-sm text-secondary font-semibold" id="deploy-marker">
      DEPLOY-TEST-0316-ASTRO
    </p>
  </div>
</footer>

<!-- Floating Action Button -->
<button
  id="contactFloatingBtn"
  class="floating-contact-btn fixed bottom-8 right-8 px-6 py-4 text-white border-0 rounded-full text-base font-semibold cursor-pointer z-[999] flex items-center gap-3 transition-all duration-300 shadow-xl hover:shadow-2xl hover:-translate-y-1 hover:scale-105 active:translate-y-0 active:scale-100"
  style="background: linear-gradient(135deg, #8b0000, #a31515); box-shadow: 0 4px 20px rgba(139,0,0,0.4);"
  aria-label="Contact"
>
  <span class="text-2xl flex items-center">✉</span>
  <span class="font-serif whitespace-nowrap">Contactează-ne</span>
</button>

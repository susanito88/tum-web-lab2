---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Events from '../components/Events.astro';
import Menu from '../components/Menu.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { getCollection, getEntry } from 'astro:content';

const siteEntry = await getEntry('settings', 'site');
const site = siteEntry.data;

const eventsRaw = await getCollection('events');
const events = eventsRaw
  .sort((a, b) => a.data.order - b.data.order)
  .map((e) => ({ title: e.data.title, description: e.data.description }));

const menuRaw = await getCollection('menu');
const menuItems = menuRaw
  .sort((a, b) => a.data.order - b.data.order)
  .map((m) => ({ name: m.data.name, description: m.data.description, animationClass: m.data.animationClass }));
---

<Layout title={`${site.restaurantName} - ${site.tagline}`} description={site.heroSubtitle}>
  <Nav restaurantName={site.restaurantName} />
  <Hero
    heroTitle={site.heroTitle}
    heroSubtitle={site.heroSubtitle}
    heroButtonText={site.heroButtonText}
    heroImageUrl={site.heroImageUrl}
  />
  <About
    aboutTitle={site.aboutTitle}
    aboutText1={site.aboutText1}
    aboutText2={site.aboutText2}
  />
  <Events eventsTitle={site.eventsTitle} events={events} />
  <Menu menuTitle={site.menuTitle} items={menuItems} />
  <Contact
    contactTitle={site.contactTitle}
    contactSubtitle={site.contactSubtitle}
    phone={site.phone}
    email={site.email}
    address={site.address}
    capacity={site.capacity}
    instagram={site.instagram}
    instagramUrl={site.instagramUrl}
  />
  <Footer restaurantName={site.restaurantName} footerText={site.footerText} />

  <!-- Mascot -->
  <div
    id="mascot"
    class="mascot fixed bottom-32 right-8 w-32 h-32 z-[998] cursor-pointer opacity-0 translate-y-24 scale-50"
  >
    <div class="mascot-inner w-full h-full">
      <svg
        class="mascot-svg w-full h-full"
        style="filter: drop-shadow(0 4px 10px rgba(0, 0, 0, 0.3))"
        viewBox="0 0 200 200"
        xmlns="http://www.w3.org/2000/svg"
      >
        <ellipse cx="100" cy="45" rx="50" ry="15" fill="#ffffff" stroke="#333" stroke-width="2" />
        <rect x="60" y="40" width="80" height="35" fill="#ffffff" stroke="#333" stroke-width="2" rx="5" />
        <path d="M 70 30 Q 75 15 85 20 Q 90 10 100 15 Q 110 10 115 20 Q 125 15 130 30" fill="#ffffff" stroke="#333" stroke-width="2" />
        <circle cx="100" cy="110" r="45" fill="#ffd6a5" stroke="#333" stroke-width="2" />
        <circle cx="88" cy="105" r="5" fill="#333" />
        <circle cx="112" cy="105" r="5" fill="#333" />
        <circle cx="90" cy="103" r="2" fill="#ffffff" />
        <circle cx="114" cy="103" r="2" fill="#ffffff" />
        <circle cx="75" cy="115" r="8" fill="#ffb3ba" opacity="0.6" />
        <circle cx="125" cy="115" r="8" fill="#ffb3ba" opacity="0.6" />
        <path d="M 85 120 Q 100 130 115 120" stroke="#333" stroke-width="2" fill="none" stroke-linecap="round" />
        <path d="M 80 115 Q 85 118 100 117 Q 115 118 120 115" stroke="#333" stroke-width="2" fill="none" />
        <rect x="70" y="150" width="60" height="45" fill="#ffffff" stroke="#333" stroke-width="2" rx="5" />
        <line x1="100" y1="155" x2="100" y2="190" stroke="#333" stroke-width="2" />
        <circle cx="85" cy="165" r="3" fill="#daa520" />
        <circle cx="85" cy="180" r="3" fill="#daa520" />
        <circle cx="115" cy="165" r="3" fill="#daa520" />
        <circle cx="115" cy="180" r="3" fill="#daa520" />
        <rect x="35" y="155" width="35" height="15" fill="#ffffff" stroke="#333" stroke-width="2" rx="7" transform="rotate(-20 52 162)" />
        <rect x="130" y="155" width="35" height="15" fill="#ffffff" stroke="#333" stroke-width="2" rx="7" transform="rotate(20 148 162)" />
        <circle cx="40" cy="165" r="8" fill="#ffd6a5" stroke="#333" stroke-width="2" />
        <ellipse cx="38" cy="175" rx="3" ry="8" fill="#c0c0c0" stroke="#333" stroke-width="1" />
        <circle cx="160" cy="165" r="8" fill="#ffd6a5" stroke="#333" stroke-width="2" />
        <line x1="162" y1="170" x2="162" y2="185" stroke="#c0c0c0" stroke-width="2" />
        <circle cx="162" cy="188" r="4" fill="none" stroke="#c0c0c0" stroke-width="2" />
        <line x1="158" y1="185" x2="166" y2="185" stroke="#c0c0c0" stroke-width="1" />
        <line x1="158" y1="188" x2="166" y2="188" stroke="#c0c0c0" stroke-width="1" />
      </svg>
    </div>
    <div
      class="mascot-tooltip absolute bottom-full right-0 text-white px-4 py-2 rounded-lg text-sm w-auto whitespace-nowrap opacity-0 invisible transition-all duration-300 font-semibold leading-normal z-[999] mb-4"
      style="background: linear-gradient(135deg, #8b0000, #a31515); box-shadow: 0 4px 15px rgba(0,0,0,0.3);"
    >
      <div class="absolute top-full right-8 border-8 border-transparent" style="border-top-color: #8b0000"></div>
      Click me!
    </div>
  </div>
</Layout>

<script>
  // Floating contact button
  const contactBtn = document.getElementById('contactFloatingBtn');
  contactBtn?.addEventListener('click', () => {
    document.getElementById('contact')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  // Scroll animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('animate-visible');
      });
    },
    { threshold: 0.15, rootMargin: '0px 0px -50px 0px' }
  );

  document
    .querySelectorAll('.scroll-animate, .scroll-fade, .scroll-slide-left, .scroll-slide-right')
    .forEach((el) => observer.observe(el));
</script>

---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Events from '../components/Events.astro';
import Menu from '../components/Menu.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import Mascot from '../components/Mascot.astro';
import PageBehavior from '../components/PageBehavior.astro';
import { getCollection, getEntry } from 'astro:content';

function toPascalCase(value) {
  return value
    .split(/[^a-zA-Z0-9]+/)
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join('');
}

const siteEntry = await getEntry('settings', 'site');
const site = siteEntry.data;
const footerEntry = await getEntry('footer', 'footer');
const footer = footerEntry.data;
const mascotEntry = await getEntry('mascot', 'mascot');
const mascot = mascotEntry.data;

const eventsRaw = await getCollection('events');
const events = eventsRaw
  .filter((e) => !e.data.hidden)
  .sort((a, b) => a.data.order - b.data.order)
  .map((e) => {
    const eventName = toPascalCase(e.id);
    return {
      title: e.data.title,
      description: e.data.description,
      titleI18nKey: `event${eventName}`,
      descriptionI18nKey: `event${eventName}Desc`,
    };
  });

const menuRaw = await getCollection('menu');
const menuItems = menuRaw
  .filter((m) => !m.data.hidden)
  .sort((a, b) => a.data.order - b.data.order)
  .map((m) => {
    const menuName = toPascalCase(m.id);
    return {
      name: m.data.name,
      description: m.data.description,
      descriptionI18nKey: `menu${menuName}Desc`,
      animationClass: m.data.animationClass,
    };
  });
---

<Layout title={`${site.restaurantName} - ${site.tagline}`} description={site.heroSubtitle}>
  <Nav restaurantName={site.restaurantName} />
  <Hero
    heroTitle={site.heroTitle}
    heroSubtitle={site.heroSubtitle}
    heroButtonText={site.heroButtonText}
    heroImageUrl={site.heroImageUrl}
  />
  <About
    aboutTitle={site.aboutTitle}
    aboutText1={site.aboutText1}
    aboutText2={site.aboutText2}
  />
  <Events eventsTitle={site.eventsTitle} events={events} />
  <Menu menuTitle={site.menuTitle} items={menuItems} />
  <Contact
    contactTitle={site.contactTitle}
    contactSubtitle={site.contactSubtitle}
    phone={site.phone}
    email={site.email}
    address={site.address}
    capacity={site.capacity}
    instagram={site.instagram}
    instagramUrl={site.instagramUrl}
  />
  <Footer
    restaurantName={site.restaurantName}
    footerText={site.footerText}
    contactButtonText={footer.contactButtonText}
    copyrightYear={footer.copyrightYear}
  />
  <Mascot tooltipText={mascot.tooltipText} />
  <PageBehavior />
</Layout>

---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Authentic Moldovan Cuisine for Unforgettable Events" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Merriweather:wght@400;700&family=Dancing+Script:wght@700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/reset.css" />
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="icon" href="/assets/images/favicon.png" type="image/x-icon" />
  </head>
  <body class="font-serif text-dark bg-white">
    <slot />
    <script src="/js/translations.js" is:inline></script>
  </body>
</html>
